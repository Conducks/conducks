{
	"name": "conducks",
	"version": "0.7.7",
	"description": "High-fidelity structural intelligence and automated governance for AI agents. Transform your code into a living Synapse Graph.",
	"keywords": [
		"mcp",
		"static-analysis",
		"governance",
		"architecture",
		"dependency-graph",
		"ai-agents",
		"codebase-mapping"
	],
	"author": "Conducks Team <contact@conducks.com>",
	"license": "Apache-2.0",
	"type": "module",
	"bin": {
		"conducks": "./build/src/interfaces/cli/index.js"
	},
	"files": [
		"build",
		"config",
		"docs",
		"LICENSE",
		"README.md"
	],
	"scripts": {
		"build": "tsc && tsc-alias && chmod +x build/src/interfaces/cli/index.js && cp package.json config/sentinel.json build/ && mkdir -p build/src/resources && cp -r src/resources/* build/src/resources/ && cp build/src/resources/grammars/tree-sitter.wasm build/src/lib/core/parsing/ && cp build/src/resources/grammars/tree-sitter.wasm build/src/interfaces/cli/",
		"start": "node ./build/src/interfaces/cli/index.js mirror",
		"demo": "npm run build && npm run start",
		"clean": "rm -rf build data .conducks",
		"prepare": "npm run build",
		"watch": "tsc --watch",
		"inspector": "npx @modelcontextprotocol/inspector build/index.js",
		"type-check": "tsc --noEmit",
		"test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --testPathIgnorePatterns='tests/legacy/archived-tests'",
		"test:unit": "cross-env NODE_OPTIONS=--experimental-vm-modules jest tests/unit",
		"test:int": "cross-env NODE_OPTIONS=--experimental-vm-modules jest tests/integration",
		"benchmark": "node --loader ts-node/esm tests/benchmark/run.ts",
		"test:persistence": "jest --config jest.persistence.config.cjs"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.22.0",
		"@toon-format/cli": "^1.0.0",
		"@toon-format/toon": "^1.0.0",
		"chokidar": "^4.0.3",
		"cors": "^2.8.5",
		"duckdb": "^1.4.4",
		"express": "^4.18.2",
		"fs-extra": "^11.3.2",
		"marked": "^5.1.2",
		"slugify": "^1.6.6",
		"tree-sitter": "^0.21.1",
		"tree-sitter-c": "0.24.1",
		"tree-sitter-c-sharp": "0.23.1",
		"tree-sitter-cpp": "0.23.4",
		"tree-sitter-go": "0.25.0",
		"tree-sitter-java": "0.23.5",
		"tree-sitter-javascript": "0.25.0",
		"tree-sitter-php": "0.24.2",
		"tree-sitter-python": "0.25.0",
		"tree-sitter-ruby": "0.23.1",
		"tree-sitter-rust": "0.24.0",
		"tree-sitter-swift": "0.7.1",
		"tree-sitter-typescript": "0.23.2"
	},
	"optionalDependencies": {
		"ajv": "^8.12.0"
	},
	"devDependencies": {
		"@types/cors": "^2.8.17",
		"@types/express": "^4.17.21",
		"@types/fs-extra": "^11.0.4",
		"@types/jest": "^30.0.0",
		"@types/marked": "^5.0.2",
		"@types/node": "^20.19.37",
		"cross-env": "^10.1.0",
		"jest": "^30.3.0",
		"ts-jest": "^29.4.6",
		"ts-node": "^10.9.2",
		"tsc-alias": "^1.8.16",
		"tsx": "^4.21.0",
		"typescript": "^5.3.3",
		"vitest": "^4.1.2"
	}
}
