{
	"name": "conducks",
	"version": "0.1.0",
	"description": "rule-only guidance for intent clarification, code hygiene, and documentation parity",
	"author": "Conducks Team",
	"private": true,
	"type": "module",
	"bin": {
		"conducks": "./build/index.js"
	},
	"files": [
		"build"
	],
	"scripts": {
		"build": "tsc && chmod 755 build/index.js && cp package.json build/ && cd build && npm install --production --ignore-scripts && cd ..",
		"prepare": "npm run build",
		"watch": "tsc --watch",
		"inspector": "npx @modelcontextprotocol/inspector build/index.js",
		"type-check": "tsc --noEmit"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.22.0",
		"@toon-format/cli": "^1.0.0",
		"@toon-format/toon": "^1.0.0",
		"chokidar": "^4.0.3",
		"cors": "^2.8.5",
		"express": "^4.18.2",
		"fs-extra": "^11.3.2",
		"marked": "^5.1.2",
		"slugify": "^1.6.6"
	},
	"optionalDependencies": {
		"ajv": "^8.12.0"
	},
	"devDependencies": {
		"@types/cors": "^2.8.17",
		"@types/express": "^4.17.21",
		"@types/fs-extra": "^11.0.4",
		"@types/marked": "^5.0.2",
		"@types/node": "^20.11.24",
		"ts-node": "^10.9.2",
		"typescript": "^5.3.3"
	}
}
