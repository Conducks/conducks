{
	"name": "conducks",
	"version": "0.1.0",
	"description": "keep agent orgianzed and memory always refresh by consolidating their docs in a organized manner",
	"author": "Conducks Team",
	"main": "electron-main.cjs",
	"private": true,
	"type": "module",
	"bin": {
		"conducks": "./build/index.js"
	},
	"files": [
		"build"
	],
	"scripts": {
		"build": "tsc && cp -r build/src/* build/ && rm -rf build/src && chmod 755 build/index.js && cp -r src/dashboard/public build/dashboard/",
		"prepare": "npm run build",
		"watch": "tsc --watch",
		"inspector": "npx @modelcontextprotocol/inspector build/index.js",
		"test": "npm run build && CONDUCKS_STORAGE_DIR=./build/test-workspace/storage node --import ./build/test/setup.js --test build/test/**/*.test.js",
		"test:verbose": "npm run build && CONDUCKS_STORAGE_DIR=./build/test-workspace/storage node --import ./build/test/setup.js --test --test-reporter=spec build/test/**/*.test.js",
		"type-check": "tsc --noEmit",
		"dashboard": "ts-node src/dashboard/server.ts",
		"start:desktop": "electron electron-main.cjs",
		"dist": "npm run build && electron-builder"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.22.0",
		"@toon-format/cli": "^1.0.0",
		"@toon-format/toon": "^1.0.0",
		"chokidar": "^4.0.3",
		"cors": "^2.8.5",
		"express": "^4.18.2",
		"fs-extra": "^11.3.2",
		"marked": "^5.1.2",
		"slugify": "^1.6.6"
	},
	"devDependencies": {
		"@types/cors": "^2.8.17",
		"@types/express": "^4.17.21",
		"@types/fs-extra": "^11.0.4",
		"@types/marked": "^5.0.2",
		"@types/node": "^20.11.24",
		"electron": "^39.2.3",
		"electron-builder": "^24.13.3",
		"ts-node": "^10.9.2",
		"typescript": "^5.3.3"
	},
	"build": {
		"appId": "com.conducks.app",
		"productName": "CONDUCKS",
		"icon": "build/dashboard/public/logo.png",
		"files": [
			"build/**/*",
			"electron-main.cjs",
			"package.json"
		],
		"directories": {
			"output": "dist"
		},
		"mac": {
			"category": "public.app-category.productivity",
			"identity": null
		},
		"win": {
			"target": "nsis"
		},
		"linux": {
			"target": "AppImage"
		}
	}
}